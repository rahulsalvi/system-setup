#!/usr/bin/env python3
"""system-setup - Run ansible-pull for bootstrapping or updating a machine."""

import argparse
import subprocess
import sys

DEFAULT_REPO_URL = "https://github.com/rahulsalvi/system-setup.git"


def build_pull_args(args: argparse.Namespace) -> list[str]:
    """Build common ansible-pull arguments."""
    pull_args = []
    if not args.no_ask_pass:
        pull_args.append("-K")
    pull_args.extend(["-U", args.repo])
    if args.checkout:
        pull_args.extend(["--checkout", args.checkout])
    if args.dry_run:
        pull_args.extend(["--check", "--diff"])
    return pull_args


def build_bootstrap_args(args: argparse.Namespace) -> list[str]:
    """Build bootstrap-specific arguments."""
    bootstrap_args = ["-e", f"machine_role={args.machine_role}"]
    if args.host_vars:
        bootstrap_args.extend(["-e", f"host_vars='{args.host_vars}'"])
    bootstrap_args.append("bootstrap.yml")
    return bootstrap_args


def do_ansible_pull(args: list[str]):
    command = ["ansible-pull"] + args
    print("Running command:")
    print(f"{' '.join(command)}")
    if input("Proceed? [Y/n] ").strip().lower() == "n":
        print("Aborted.")
        sys.exit(1)
    subprocess.run(command, check=True)


def do_bootstrap(args: argparse.Namespace) -> None:
    print(f"Bootstrapping as role: {args.machine_role}")
    pull_args = build_pull_args(args) + build_bootstrap_args(args)
    do_ansible_pull(pull_args)


def do_update(args: argparse.Namespace) -> None:
    print("Updating...")
    pull_args = build_pull_args(args)
    do_ansible_pull(pull_args)


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="system-setup",
        description="Run ansible-pull for bootstrapping or updating a machine.",
    )
    parser.add_argument(
        "--repo",
        default=DEFAULT_REPO_URL,
        help=f"Repository URL (default: {DEFAULT_REPO_URL})",
    )
    parser.add_argument(
        "--checkout",
        default=None,
        help="Branch/tag/commit to checkout (default: main)",
    )
    parser.add_argument(
        "--no-ask-pass",
        action="store_true",
        help="Do not ask for sudo password",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Run in check mode with diff output",
    )

    subparsers = parser.add_subparsers(dest="command")

    bootstrap_parser = subparsers.add_parser(
        "bootstrap",
        help="Bootstrap the machine with the given role",
    )
    bootstrap_parser.add_argument(
        "machine_role",
        help="Machine role",
    )
    bootstrap_parser.add_argument(
        "host_vars",
        nargs="?",
        default=None,
        help="Comma-separated key=value pairs to override role defaults",
    )
    bootstrap_parser.set_defaults(func=do_bootstrap)

    update_parser = subparsers.add_parser(
        "update",
        help="Re-run the main playbook to apply updates",
    )
    update_parser.set_defaults(func=do_update)

    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    args.func(args)


if __name__ == "__main__":
    main()
